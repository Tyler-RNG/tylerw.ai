---
import { site } from '../data/site';
import Terminal from './Terminal.astro';
---

<section class="hero" id="top">
  <div class="grid-bg"></div>
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">{site.eyebrow}</p>
      <h1 class="hero-name">{site.name}</h1>
      <p class="hero-tagline">{site.tagline}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={site.cta.href}>{site.cta.label}</a>
        <a class="btn btn-ghost" href={site.group.href} target="_blank" rel="noopener">
          {site.group.label}
        </a>
      </div>
    </div>

    <div class="hero-term">
      <Terminal />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(48px, 8vw, 96px);
  }
  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    align-items: center;
    gap: clamp(28px, 5vw, 64px);
  }
  .hero-copy {
    position: relative;
  }
  .hero-name {
    font-size: clamp(40px, 7vw, 68px);
    font-weight: var(--ag-fw-semi);
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: var(--ag-text-bright);
    margin: 14px 0 0;
  }
  .hero-tagline {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--ag-muted);
    line-height: 1.55;
    max-width: 34ch;
    margin-top: 18px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-term {
    position: relative;
  }

  @media (max-width: 860px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
