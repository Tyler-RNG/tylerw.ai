---
import { site } from '../data/site';
import Icon from './Icon.astro';
---

<section class="section contact" id="contact">
  <div class="container">
    <div class="panel">
      <div class="grid-bg"></div>
      <div class="panel-inner">
        <p class="eyebrow">Contact</p>
        <h2 class="section-title">Let's build your next move.</h2>
        <p class="sub">One clear next step. Book a session and we'll get into it.</p>

        <div class="actions">
          <a class="btn btn-primary" href={site.cta.href} target="_blank" rel="noopener">
            <Icon name="calendar" size={18} />
            {site.cta.label}
          </a>
          <a class="btn btn-ghost" href={`mailto:${site.email}`}>
            <Icon name="mail" size={18} />
            <span class="mono">{site.email}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .panel {
    position: relative;
    overflow: hidden;
    background: var(--ag-panel);
    border: 1px solid var(--ag-border);
    border-radius: var(--ag-radius-lg);
    padding: clamp(32px, 6vw, 64px);
    text-align: center;
  }
  .panel-inner {
    position: relative;
  }
  .eyebrow {
    display: block;
  }
  .section-title {
    margin-top: 12px;
  }
  .sub {
    margin: 14px auto 0;
    color: var(--ag-muted);
    font-size: clamp(15px, 2vw, 17px);
    max-width: 46ch;
  }
  .actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
</style>
