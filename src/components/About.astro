---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import headshot from '../assets/headshot.png';
---

<section class="section about" id="about">
  <div class="container about-inner">
    <div class="about-photo">
      <span class="halo" aria-hidden="true"></span>
      <span class="frame">
        <Image
          src={headshot}
          alt={`Portrait of ${site.name}`}
          width={300}
          height={300}
          densities={[1, 2]}
          loading="lazy"
        />
      </span>
    </div>

    <div class="about-copy">
      <p class="eyebrow">About</p>
      {site.about.body.map((para) => <p class="para">{para}</p>)}

      {
        site.about.status && (
          <p class="status">
            <span class:list={['dot', { live: site.about.status.live }]} aria-hidden="true" />
            <span class="mono">{site.about.status.label}</span>
          </p>
        )
      }
    </div>
  </div>
</section>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    align-items: center;
    gap: clamp(28px, 5vw, 64px);
  }
  .about-photo {
    position: relative;
    width: 240px;
    aspect-ratio: 1;
    justify-self: center;
  }
  .about-photo .halo {
    position: absolute;
    inset: -14%;
    border-radius: 999px;
    background: radial-gradient(circle, var(--ag-accent-50), transparent 64%);
    opacity: 0.45;
  }
  .about-photo .frame {
    position: absolute;
    inset: 0;
    display: block;
    border-radius: 999px;
    overflow: hidden;
    background: var(--ag-panel);
    border: 2px solid var(--ag-accent-50);
    box-shadow: var(--ag-glow-accent);
  }
  .about-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 26%;
  }

  .para {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--ag-text-2);
    line-height: 1.6;
    max-width: 56ch;
  }
  .para + .para {
    margin-top: 16px;
    color: var(--ag-muted);
  }
  .eyebrow {
    margin-bottom: 16px;
    display: block;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-size: var(--ag-fs-small);
    color: var(--ag-muted);
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--ag-muted);
  }
  .dot.live {
    background: var(--ag-green);
    box-shadow: var(--ag-glow-green);
  }

  @media (max-width: 740px) {
    .about-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .para {
      margin-inline: auto;
    }
    .eyebrow {
      margin-top: 8px;
    }
  }
</style>
