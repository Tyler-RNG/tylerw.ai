---
import { site } from '../data/site';
const { user, host, command, intro, entries } = site.terminal;
const pad = Math.max(...entries.map((e) => e.key.length)) + 2;
---

<div class="term" role="img" aria-label={`Terminal listing what ${site.name} offers`}>
  <div class="bar">
    <span class="ttl mono">coach — bash</span>
    <span class="ctl mono" aria-hidden="true">—&nbsp;&nbsp;▢&nbsp;&nbsp;✕</span>
  </div>
  <div class="body mono">
    <div class="line">
      <span class="u">{user}@{host}</span><span class="c">:</span><span class="t">~</span><span
        class="d">$</span
      > <span class="cmd">{command}</span>
    </div>
    <div class="intro">{intro}</div>
    {
      entries.map((e) => (
        <div class="line entry">
          <span class="key">{e.key.padEnd(pad, ' ')}</span>
          <span class="val">{e.desc}</span>
        </div>
      ))
    }
    <div class="line prompt">
      <span class="u">{user}@{host}</span><span class="c">:</span><span class="t">~</span><span
        class="d">$</span
      ><span class="cursor"></span>
    </div>
  </div>
</div>

<style>
  .term {
    width: 100%;
    border: 1px solid var(--ag-border-2);
    border-radius: var(--ag-radius-md);
    overflow: hidden;
    background: var(--ag-well);
    box-shadow: 0 22px 50px -28px rgba(0, 0, 0, 0.8);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border-bottom: 1px solid var(--ag-border);
    background: var(--ag-inset-2);
  }
  .ttl {
    font-size: var(--ag-fs-small);
    color: var(--ag-muted);
  }
  .ctl {
    font-size: var(--ag-fs-small);
    color: var(--ag-muted);
    line-height: 1;
    opacity: 0.7;
  }
  .body {
    padding: 18px 18px 20px;
    font-size: clamp(12px, 1.5vw, 14px);
    line-height: 1.85;
  }
  .u {
    color: var(--ag-green);
  }
  .c,
  .d {
    color: var(--ag-muted);
  }
  .t {
    color: var(--ag-accent);
  }
  .cmd {
    color: var(--ag-text);
  }
  .intro {
    color: var(--ag-muted);
    margin: 4px 0 8px;
  }
  .key {
    color: #9fc0ff;
    white-space: pre;
  }
  .val {
    color: var(--ag-text-3);
  }
  .entry {
    transition: transform var(--ag-dur-base) var(--ag-ease);
  }
  .prompt {
    margin-top: 8px;
  }
</style>
