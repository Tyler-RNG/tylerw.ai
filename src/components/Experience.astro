---
import { site } from '../data/site';
import Icon from './Icon.astro';
const { experience, experienceIntro } = site;
---

<section class="section experience" id="experience">
  <div class="container">
    <p class="eyebrow">Background</p>
    <h2 class="section-title">Where I've been.</h2>
    <p class="intro">{experienceIntro}</p>

    <ol class="timeline">
      {
        experience.map((e) => (
          <li class="row">
            <span class="ic" aria-hidden="true">
              <Icon name="briefcase" size={18} />
            </span>
            <div class="body">
              <div class="top">
                <h3 class="org">{e.org}</h3>
                <span class="role mono">{e.role}</span>
              </div>
              <p class="note">{e.note}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section-title {
    margin-top: 8px;
  }
  .intro {
    margin-top: 14px;
    color: var(--ag-muted);
    font-size: clamp(15px, 2vw, 18px);
    max-width: 60ch;
    line-height: 1.55;
  }
  .timeline {
    list-style: none;
    margin: 36px 0 0;
    padding: 0;
    border: 1px solid var(--ag-border);
    border-radius: var(--ag-radius-md);
    background: var(--ag-panel);
    overflow: hidden;
  }
  .row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
  }
  .row + .row {
    border-top: 1px solid var(--ag-border);
  }
  .ic {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex: none;
    border-radius: var(--ag-radius-sm);
    background: var(--ag-accent-12);
    color: var(--ag-accent);
    margin-top: 1px;
  }
  .top {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }
  .org {
    font-size: var(--ag-fs-h2);
    font-weight: var(--ag-fw-semi);
    color: var(--ag-text-bright);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .role {
    font-size: var(--ag-fs-small);
    color: var(--ag-accent);
    letter-spacing: 0.02em;
  }
  .note {
    margin-top: 4px;
    color: var(--ag-muted);
    font-size: var(--ag-fs-body);
    line-height: 1.5;
  }
</style>
