---
import { site } from '../data/site';
const testimonials = site.testimonials;
---

{
  testimonials.length > 0 && (
    <section class="section proof" id="proof">
      <div class="container">
        <p class="eyebrow">Proof</p>
        <h2 class="section-title">What people say.</h2>
        <div class="grid">
          {testimonials.map((t) => (
            <figure class="card quote">
              <blockquote>"{t.quote}"</blockquote>
              <figcaption>
                <span class="author">{t.author}</span>
                <span class="role mono">{t.role}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .section-title {
    margin-top: 8px;
  }
  .grid {
    margin-top: 36px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
  }
  .quote {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  blockquote {
    margin: 0;
    font-size: var(--ag-fs-body);
    color: var(--ag-text-2);
    line-height: 1.6;
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-top: 1px solid var(--ag-border);
    padding-top: 14px;
  }
  .author {
    font-weight: var(--ag-fw-semi);
    color: var(--ag-text-bright);
    font-size: var(--ag-fs-base);
  }
  .role {
    font-size: var(--ag-fs-mini);
    color: var(--ag-muted);
  }
</style>
